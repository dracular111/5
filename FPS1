repeat task.wait() until game:IsLoaded()

pcall(function()
    -- Ngắt connection cũ
    if getgenv().fps_loop then
        getgenv().fps_loop:Disconnect()
        getgenv().fps_loop = nil
    end

    -- Hủy thread cũ
    if getgenv().fps_thread then
        task.cancel(getgenv().fps_thread)
        getgenv().fps_thread = nil
    end

    -- Xóa UI cũ
    local CoreGui = game:GetService("CoreGui")
    local Old = CoreGui:FindFirstChild("FPS_UI")
    if Old then
        Old:Destroy()
    end
end)

local FPS_CAP = 3

if setfpscap then
    pcall(setfpscap, FPS_CAP)
end

local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "FPS_UI"
ScreenGui.IgnoreGuiInset = true
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = CoreGui

local Label = Instance.new("TextLabel")
Label.Size = UDim2.new(0, 500, 0, 120)
Label.Position = UDim2.new(0.5, -250, 0, 80)
Label.BackgroundTransparency = 1
Label.Font = Enum.Font.Code
Label.TextSize = 50
Label.TextColor3 = Color3.fromRGB(255,255,0)
Label.TextStrokeTransparency = 0.3
Label.TextStrokeColor3 = Color3.new(0,0,0)
Label.Parent = ScreenGui

local fps = 0

getgenv().fps_loop = RunService.RenderStepped:Connect(function(dt)
    fps = math.floor(1 / math.max(dt, 0.0001))
end)

getgenv().fps_thread = task.spawn(function()
    while true do
        task.wait(1)

        if not ScreenGui.Parent then
            break
        end

        Label.Text = ("FPS %d/%d"):format(fps, FPS_CAP)
    end
end)
