-- ✅ GIỮ NGUYÊN MỌI THỨ BÊN DƯỚI
-- FPS hiển thị ngay, nhưng chỉ lock sau 1 phút 30s
local fps = 0
local fpsCapActive = false

getgenv().fps_loop = RunService.RenderStepped:Connect(function(dt)
    fps = math.floor(1 / (dt > 0 and dt or 0.0001))
end)

task.spawn(function()
    while task.wait(5) do

        if not Label or not Label.Parent then
            break
        end

        if fpsCapActive then

            local displayTarget

            if FPS_MODE == "LOCK" then

                displayTarget = LOCK_FPS

            else

                local inInstance = false
                if InstancingCmds then
                    pcall(function()
                        inInstance = InstancingCmds.IsInInstance()
                    end)
                end

                displayTarget = inInstance and FPS_EVENT or FPS_WORLD
            end

            Label.Text = string.format(
                "FPS %d/%d",
                fps,
                displayTarget
            )

        else

            Label.Text = string.format("FPS %d/...", fps)

        end
    end
end)

task.spawn(function()

    task.wait(10)

    fpsCapActive = true

    getgenv().fps_thread_stop = false

    getgenv().fps_thread = task.spawn(function()

        local currentFPS

        while not getgenv().fps_thread_stop do

            local targetFPS

            if FPS_MODE == "LOCK" then

                targetFPS = LOCK_FPS

            else

                local inInstance = false

                if InstancingCmds then
                    pcall(function()
                      inInstance = InstancingCmds.IsInInstance()
                    end)
                end

                targetFPS = inInstance and FPS_EVENT or FPS_WORLD
            end

            if targetFPS ~= currentFPS then

                currentFPS = targetFPS

                if setfpscap then
                    pcall(setfpscap, targetFPS)
                end

            end

            task.wait(10)
        end
    end)

end)
